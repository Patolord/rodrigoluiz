---
// A small SVG duck that waddles across the bottom of the viewport.
// Respects prefers-reduced-motion.
---

<div id="duck-stage">
  <button
    id="duck"
    type="button"
    aria-label="Quack"
    title="Quack!"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 64 48"
      width="48"
      height="36"
    >
      <!-- body -->
      <ellipse cx="28" cy="30" rx="20" ry="13" fill="#f6c453" />
      <!-- chest highlight -->
      <ellipse cx="22" cy="34" rx="10" ry="6" fill="#fcd97a" opacity="0.7" />
      <!-- tail -->
      <path d="M8 26 L2 22 L8 30 Z" fill="#f6c453" />
      <!-- head -->
      <circle cx="46" cy="18" r="11" fill="#f6c453" />
      <!-- cheek -->
      <circle cx="44" cy="21" r="2.2" fill="#f4a8a8" opacity="0.6" />
      <!-- eye -->
      <circle cx="49" cy="15" r="2" fill="#1b1b1b" />
      <circle cx="49.7" cy="14.4" r="0.6" fill="#ffffff" />
      <!-- beak -->
      <g class="duck-beak">
        <path d="M55 17 Q63 19 55 22 Z" fill="#f08a3e" />
      </g>
      <!-- wing -->
      <g class="duck-wing">
        <path
          d="M22 22 Q32 18 38 28 Q30 32 22 30 Z"
          fill="#e8a92a"
        />
      </g>
      <!-- legs -->
      <g class="duck-legs">
        <rect class="leg leg-back" x="22" y="40" width="2.4" height="6" fill="#f08a3e" />
        <rect class="leg leg-front" x="30" y="40" width="2.4" height="6" fill="#f08a3e" />
      </g>
    </svg>
  </button>
</div>

<script>
  const duck = document.getElementById("duck");
  if (duck && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    let audioCtx: AudioContext | null = null;

    const getCtx = (): AudioContext => {
      if (!audioCtx) {
        const Ctor =
          window.AudioContext ||
          (window as unknown as { webkitAudioContext: typeof AudioContext })
            .webkitAudioContext;
        audioCtx = new Ctor();
      }
      return audioCtx;
    };

    // Decode the quack mp3 once and reuse the buffer for every click.
    // Lazily fetched on first interaction so it never blocks page load.
    const QUACK_URL = "/quack.mp3";
    let quackBuffer: AudioBuffer | null = null;
    let quackLoad: Promise<AudioBuffer> | null = null;

    const loadQuack = (): Promise<AudioBuffer> => {
      if (quackBuffer) return Promise.resolve(quackBuffer);
      if (quackLoad) return quackLoad;
      const ctx = getCtx();
      quackLoad = fetch(QUACK_URL)
        .then((r) => {
          if (!r.ok) throw new Error(`quack fetch failed: ${r.status}`);
          return r.arrayBuffer();
        })
        .then((data) => ctx.decodeAudioData(data))
        .then((buf) => {
          quackBuffer = buf;
          return buf;
        });
      return quackLoad;
    };

    const playQuack = () => {
      const ctx = getCtx();
      if (ctx.state === "suspended") void ctx.resume();

      const start = (buf: AudioBuffer) => {
        const src = ctx.createBufferSource();
        src.buffer = buf;
        // small random pitch nudge so repeated quacks vary slightly
        src.playbackRate.value = 0.95 + Math.random() * 0.12;
        const gain = ctx.createGain();
        gain.gain.value = 0.9;
        src.connect(gain).connect(ctx.destination);
        src.start();
      };

      if (quackBuffer) {
        start(quackBuffer);
      } else {
        loadQuack().then(start).catch(() => {
          // silent fallback if mp3 is missing
        });
      }
    };

    duck.addEventListener("click", () => {
      playQuack();
      duck.classList.remove("is-quacking");
      // restart animation
      void (duck as HTMLElement).offsetWidth;
      duck.classList.add("is-quacking");
    });

    duck.addEventListener("animationend", (e) => {
      if ((e as AnimationEvent).animationName === "duck-click-quack") {
        duck.classList.remove("is-quacking");
      }
    });
  }
</script>

<style>
  #duck-stage {
    position: fixed;
    left: 0;
    bottom: 8px;
    width: 100%;
    height: 0;
    pointer-events: none;
    z-index: 40;
    overflow: visible;
  }

  #duck {
    position: absolute;
    bottom: 0;
    left: -80px;
    transform-origin: center bottom;
    animation: duck-walk 22s linear infinite;
    will-change: transform;
    /* re-enable interaction (stage disables it) */
    pointer-events: auto;
    cursor: pointer;
    background: none;
    border: 0;
    padding: 0;
    margin: 0;
    color: inherit;
    font: inherit;
    -webkit-tap-highlight-color: transparent;
  }

  #duck:focus-visible {
    outline: 2px solid #f08a3e;
    outline-offset: 4px;
    border-radius: 50%;
  }

  /* squish reaction on click */
  #duck.is-quacking svg {
    animation:
      duck-bob 0.55s ease-in-out infinite,
      duck-click-quack 0.45s ease-out;
  }

  /* exaggerated beak open while quacking */
  #duck.is-quacking .duck-beak {
    animation: duck-beak-open 0.45s ease-out;
  }

  /* gentle vertical bob */
  #duck svg {
    display: block;
    animation: duck-bob 0.55s ease-in-out infinite;
    transform-origin: center bottom;
  }

  /* wing flap */
  .duck-wing {
    transform-origin: 28px 26px;
    animation: duck-wing 0.7s ease-in-out infinite;
  }

  /* beak quack */
  .duck-beak {
    transform-origin: 55px 19px;
    animation: duck-quack 3.2s ease-in-out infinite;
  }

  /* legs alternating */
  .leg-front {
    transform-origin: 31px 40px;
    animation: duck-leg 0.55s ease-in-out infinite;
  }
  .leg-back {
    transform-origin: 23px 40px;
    animation: duck-leg 0.55s ease-in-out infinite;
    animation-delay: 0.275s;
  }

  @keyframes duck-walk {
    0% {
      transform: translateX(0) scaleX(1);
    }
    45% {
      transform: translateX(calc(100vw + 80px)) scaleX(1);
    }
    50% {
      transform: translateX(calc(100vw + 80px)) scaleX(-1);
    }
    95% {
      transform: translateX(0) scaleX(-1);
    }
    100% {
      transform: translateX(0) scaleX(1);
    }
  }

  @keyframes duck-bob {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-2px);
    }
  }

  @keyframes duck-wing {
    0%, 100% {
      transform: rotate(0deg);
    }
    50% {
      transform: rotate(-15deg);
    }
  }

  @keyframes duck-leg {
    0%, 100% {
      transform: rotate(20deg);
    }
    50% {
      transform: rotate(-20deg);
    }
  }

  @keyframes duck-quack {
    0%, 88%, 100% {
      transform: rotate(0deg);
    }
    92%, 96% {
      transform: rotate(-12deg);
    }
  }

  /* extra animations for click feedback */
  @keyframes duck-click-quack {
    0% {
      transform: translateY(0) scale(1, 1);
    }
    20% {
      transform: translateY(2px) scale(1.12, 0.88);
    }
    50% {
      transform: translateY(-6px) scale(0.94, 1.06);
    }
    100% {
      transform: translateY(0) scale(1, 1);
    }
  }

  @keyframes duck-beak-open {
    0%, 100% {
      transform: rotate(0deg);
    }
    30%, 70% {
      transform: rotate(-22deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #duck,
    #duck svg,
    .duck-wing,
    .duck-beak,
    .leg-front,
    .leg-back {
      animation: none !important;
    }
    #duck-stage {
      display: none;
    }
  }
</style>
