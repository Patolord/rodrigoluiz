---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Home";
---

<BaseLayout title={pageTitle}>
  <!-- Title - stays clear, no blur -->
  <h1
    class="text-5xl font-normal italic mb-4 text-center mt-16 select-none tracking-tight leading-tight"
  >
    Tudo é interessante se você olhar de perto.
  </h1>

  <!-- Everything below title - wrapped in blur animation -->
  <div
    class="motion-safe:animate-[unblurContent_3s_ease-out_forwards]"
    style="filter: blur(8px);"
  >
    <div class="prose prose-lg max-w-none space-y-12 mt-16">
      <!-- About -->
      <section>
        <h2 class="text-3xl font-bold mb-6">Sobre</h2>

        <div class="flex flex-col sm:flex-row gap-6 sm:items-center">
          <div class="avatar flex-shrink-0 mx-auto sm:mx-0">
            <div class="w-40 rounded-full">
              <img src="/profile-pic.jpg" alt="Profile" />
            </div>
          </div>

          <div class="flex-1">
            <p class="text-lg leading-relaxed text-center sm:text-left">
              Quase tudo que importa se decide nos detalhes. Uma palavra
              escolhida com cuidado, uma pausa antes de responder, um gesto
              pensado. Em cada coisa a que se dedica atenção, cria-se uma
              profundidade que antes não existia.
            </p>
          </div>
        </div>
      </section>

      <!-- Projects -->
      <section class="space-y-6">
        <h2 class="text-3xl font-bold">Projetos</h2>
        <p class="text-base text-base-content/70">
          Áreas onde costumo trabalhar, unindo tecnologia, design e clareza
          para criar soluções que realmente funcionam.
        </p>

        <div class="grid gap-6 md:grid-cols-2">
          <!-- Produtos Digitais -->
          <div
            class="card bg-base-200 shadow-sm hover:bg-base-300 transition-colors"
          >
            <div class="card-body">
              <h3 class="card-title text-lg">🧭 Produtos Digitais</h3>
              <p>
                Criação de produtos web completos, do conceito ao lançamento.
                Aplicações estáveis, fáceis de usar e mantidas com foco em longo
                prazo.
              </p>
            </div>
          </div>

          <!-- Ecossistemas e Automação -->
          <div
            class="card bg-base-200 shadow-sm hover:bg-base-300 transition-colors"
          >
            <div class="card-body">
              <h3 class="card-title text-lg">🔗 Ecossistemas e Automação</h3>
              <p>
                Integração entre sistemas, APIs e processos internos. Redução de
                tarefas manuais e criação de fluxos automáticos que poupam tempo
                e erros.
              </p>
            </div>
          </div>

          <!-- Experiências de Marca -->
          <div
            class="card bg-base-200 shadow-sm hover:bg-base-300 transition-colors"
          >
            <div class="card-body">
              <h3 class="card-title text-lg">🌐 Experiências de Marca</h3>
              <p>
                Desenvolvimento de sites e interfaces que traduzem a identidade
                da marca. Foco em design limpo, velocidade e uma experiência
                envolvente.
              </p>
            </div>
          </div>

          <!-- Soluções Empresariais -->
          <div
            class="card bg-base-200 shadow-sm hover:bg-base-300 transition-colors"
          >
            <div class="card-body">
              <h3 class="card-title text-lg">🏢 Soluções Empresariais</h3>
              <p>
                Construção de sistemas sob medida com base nas regras e fluxos
                de cada negócio. Ferramentas internas que trazem visibilidade e
                controle real sobre operações.
              </p>
            </div>
          </div>

          <!-- Experimentos e Protótipos -->
          <div
            class="card bg-base-200 shadow-sm hover:bg-base-300 transition-colors md:col-span-2"
          >
            <div class="card-body">
              <h3 class="card-title text-lg">🧪 Experimentos e Protótipos</h3>
              <p>
                Desenvolvimento rápido de ideias, conceitos e novas tecnologias.
                Espaço para testar hipóteses e transformar curiosidade em
                aprendizado real.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Philosophy -->
      <section class="space-y-6">
        <h2 class="text-3xl font-bold">Filosofia</h2>
        <p class="text-lg leading-relaxed text-base-content/80">
          Aqui guardo citações e ideias que refletem princípios que acredito.
        </p>

        <div id="quotes-container" class="space-y-2"></div>

        <div class="text-center mt-4">
          <button id="shuffle-btn" class="btn btn-primary">
            🎲 Tente a sorte
          </button>
        </div>
      </section>

      <script>
        import {
          QuoteShuffler,
          renderQuote,
          type Quote,
        } from "../utils/quotes";

        const quotes: Quote[] = [
          {
            text: "A ferramenta não é o trabalho.",
            author: "Marshall McLuhan",
          },
          {
            text: "Um problema bem definido é um problema meio resolvido.",
            author: "Charles F. Kettering",
          },
          {
            text: "O primeiro princípio é que você não deve enganar a si mesmo, e você é a pessoa mais fácil de enganar.",
            author: "Richard Feynman",
          },
          {
            text: "Eu aprendi desde cedo a diferenca entre saber o nome de algo e saber sobre algo.",
            author: "Richard Feynman",
          },
          {
            text: "A arquitetura é a arte de organizar o pensamento.",
            author: "Le Corbusier",
          },
          {
            text: "O propósito de um sistema é o que ele faz.",
            author: "Stafford Beer",
          },
          {
            text: "Você só vive uma vez, mas se fizer isso direito, uma vez é o bastante.",
            author: "Mae West",
          },
          {
            text: "Seja você mesmo; todos os outros já existem.",
            author: "Oscar Wilde",
          },
          {
            text: "Viva como se fosse morrer amanhã. Aprenda como se fosse viver para sempre.",
            author: "Mahatma Gandhi",
          },
          {
            text: "Se você diz a verdade, não precisa se lembrar de nada.",
            author: "Mark Twain",
          },
          {
            text: "No meio da dificuldade encontra-se a oportunidade.",
            author: "Albert Einstein",
          },
          {
            text: "O certo continua sendo certo, mesmo que ninguém o faça; o errado continua sendo errado, mesmo que todos o façam.",
            author: "Santo Agostinho",
          },
          {
            text: "Não é o que acontece com você, mas como você reage ao que acontece que importa.",
            author: "Epicteto",
          },
          {
            text: "A felicidade da sua vida depende da qualidade dos seus pensamentos.",
            author: "Marco Aurélio",
          },
          {
            text: "Simplicidade é subtrair o óbvio e adicionar o significativo.",
            author: "John Maeda",
          },
        ];

        const shuffler = new QuoteShuffler(quotes);

        function displayQuotes() {
          const container = document.getElementById("quotes-container");
          if (!container) return;

          const quote = shuffler.getRandomQuote();
          container.innerHTML = renderQuote(quote);
        }

        // Display quotes on load
        displayQuotes();

        // Shuffle button
        const shuffleBtn = document.getElementById("shuffle-btn");
        if (shuffleBtn) {
          shuffleBtn.addEventListener("click", displayQuotes);
        }
      </script>

      <!-- Contact -->
      <section>
        <h2 class="text-3xl font-bold mb-6">Contato</h2>
        <p class="text-lg leading-relaxed">
          <strong>Mais:</strong>
          <a
            href="https://github.com/patolord"
            target="_blank"
            class="link link-primary">GitHub</a
          ><br />
          <strong>Fale comigo:</strong> via GitHub ou LinkedIn
        </p>
      </section>

      <!-- Comments -->
      <section>
        <h2 class="text-3xl font-bold mb-6">Comentários</h2>
        <div class="giscus"></div>
      </section>

      <script>
        import { initGiscus, setupGiscusThemeObserver } from "../utils/giscus";

        // Initialize Giscus on page load
        initGiscus();

        // Setup theme change observer
        setupGiscusThemeObserver();
      </script>
    </div>
    <!-- End of blur wrapper -->
  </div>

  <style is:global>
    @keyframes unblurContent {
      0% {
        filter: blur(8px);
        opacity: 0.6;
      }
      100% {
        filter: blur(0);
        opacity: 1;
      }
    }

    /* accessibility: disable motion */
    @media (prefers-reduced-motion: reduce) {
      .motion-safe\:animate-\[unblurContent_1\.8s_ease-out_forwards] {
        animation: none !important;
        opacity: 1 !important;
        filter: none !important;
      }
    }
  </style>
</BaseLayout>
