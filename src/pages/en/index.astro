---
import BaseLayout from "../../layouts/BaseLayout.astro";
const pageTitle = "Home";
---

<BaseLayout title={pageTitle}>
  <!-- Title - stays clear, no blur -->
  <h1
    class="text-5xl font-normal italic mb-4 text-center mt-16 select-none tracking-tight leading-tight"
  >
    Everything is interesting if you look close enough.
  </h1>

  <!-- Everything below title - wrapped in blur animation -->
  <div
    class="motion-safe:animate-[unblurContent_1.8s_ease-out_forwards]"
    style="filter: blur(8px);"
  >
    <div class="prose prose-lg max-w-none space-y-12 mt-16">
      <!-- About -->
      <section>
        <h2 class="text-3xl font-bold mb-6">About</h2>

        <div class="flex gap-6 items-center">
          <div class="avatar flex-shrink-0">
            <div class="w-40 rounded-full">
              <img src="/profile-pic.jpg" alt="Profile" />
            </div>
          </div>

          <div class="flex-1">
            <p class="text-lg leading-relaxed">
              Almost everything that matters is decided in the details. A
              word chosen with care, a pause before answering, a deliberate
              gesture. Anything you give attention to gains a depth it didn't
              have before.
            </p>
          </div>
        </div>
      </section>

      <!-- Projects -->
      <section class="space-y-6">
        <h2 class="text-3xl font-bold">Projects</h2>
        <p class="text-base text-base-content/70">
          Areas where I usually work, combining technology, design, and
          clarity to create solutions that really work.
        </p>

        <div class="grid gap-6 md:grid-cols-2">
          <!-- Digital Products -->
          <div
            class="card bg-base-200 shadow-sm hover:bg-base-300 transition-colors"
          >
            <div class="card-body">
              <h3 class="card-title text-lg">🧭 Digital Products</h3>
              <p>
                Creation of complete web products, from concept to launch.
                Stable applications, easy to use and maintained with a long-term
                focus.
              </p>
            </div>
          </div>

          <!-- Ecosystems and Automation -->
          <div
            class="card bg-base-200 shadow-sm hover:bg-base-300 transition-colors"
          >
            <div class="card-body">
              <h3 class="card-title text-lg">🔗 Ecosystems and Automation</h3>
              <p>
                Integration between systems, APIs, and internal processes.
                Reduction of manual tasks and creation of automatic flows that
                save time and errors.
              </p>
            </div>
          </div>

          <!-- Brand Experiences -->
          <div
            class="card bg-base-200 shadow-sm hover:bg-base-300 transition-colors"
          >
            <div class="card-body">
              <h3 class="card-title text-lg">🌐 Brand Experiences</h3>
              <p>
                Development of sites and interfaces that translate brand
                identity. Focus on clean design, speed, and an engaging
                experience.
              </p>
            </div>
          </div>

          <!-- Business Solutions -->
          <div
            class="card bg-base-200 shadow-sm hover:bg-base-300 transition-colors"
          >
            <div class="card-body">
              <h3 class="card-title text-lg">🏢 Business Solutions</h3>
              <p>
                Building custom systems based on the rules and flows of each
                business. Internal tools that bring visibility and real control
                over operations.
              </p>
            </div>
          </div>

          <!-- Experiments and Prototypes -->
          <div
            class="card bg-base-200 shadow-sm hover:bg-base-300 transition-colors md:col-span-2"
          >
            <div class="card-body">
              <h3 class="card-title text-lg">🧪 Experiments and Prototypes</h3>
              <p>
                Rapid development of ideas, concepts, and new technologies.
                Space to test hypotheses and transform curiosity into real
                learning.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Philosophy -->
      <section class="space-y-6">
        <h2 class="text-3xl font-bold">Philosophy</h2>
        <p class="text-lg leading-relaxed text-base-content/80">
          Here I keep quotes and ideas that reflect principles I believe in.
        </p>

        <div id="quotes-container" class="space-y-2"></div>

        <div class="text-center mt-4">
          <button id="shuffle-btn" class="btn btn-primary">
            🎲 Try your luck
          </button>
        </div>
      </section>

      <script>
        import {
          QuoteShuffler,
          renderQuote,
          type Quote,
        } from "../../utils/quotes";

        const quotes: Quote[] = [
          {
            text: "The tool is not the work.",
            author: "Marshall McLuhan",
          },
          {
            text: "A problem well stated is a problem half solved.",
            author: "Charles F. Kettering",
          },
          {
            text: "The first principle is that you must not fool yourself, and you are the easiest person to fool.",
            author: "Richard Feynman",
          },
          {
            text: "I learned very early the difference between knowing the name of something and knowing something.",
            author: "Richard Feynman",
          },
          {
            text: "Architecture is the art of organizing thought.",
            author: "Le Corbusier",
          },
          {
            text: "The purpose of a system is what it does.",
            author: "Stafford Beer",
          },
          {
            text: "You only live once, but if you do it right, once is enough.",
            author: "Mae West",
          },
          {
            text: "Be yourself; everyone else is already taken.",
            author: "Oscar Wilde",
          },
          {
            text: "Live as if you were to die tomorrow. Learn as if you were to live forever.",
            author: "Mahatma Gandhi",
          },
          {
            text: "If you tell the truth, you don't have to remember anything.",
            author: "Mark Twain",
          },
          {
            text: "In the middle of difficulty lies opportunity.",
            author: "Albert Einstein",
          },
          {
            text: "Right is right even if no one is doing it; wrong is wrong even if everyone is doing it.",
            author: "Saint Augustine",
          },
          {
            text: "It's not what happens to you, but how you react to it that matters.",
            author: "Epictetus",
          },
          {
            text: "The happiness of your life depends on the quality of your thoughts.",
            author: "Marcus Aurelius",
          },
          {
            text: "Simplicity is about subtracting the obvious and adding the meaningful.",
            author: "John Maeda",
          },
        ];

        const shuffler = new QuoteShuffler(quotes);

        function displayQuotes() {
          const container = document.getElementById("quotes-container");
          if (!container) return;

          const quote = shuffler.getRandomQuote();
          container.innerHTML = renderQuote(quote);
        }

        // Display quotes on load
        displayQuotes();

        // Shuffle button
        const shuffleBtn = document.getElementById("shuffle-btn");
        if (shuffleBtn) {
          shuffleBtn.addEventListener("click", displayQuotes);
        }
      </script>

      <!-- Contact -->
      <section>
        <h2 class="text-3xl font-bold mb-6">Contact</h2>
        <p class="text-lg leading-relaxed">
          <strong>More:</strong>
          <a
            href="https://github.com/patolord"
            target="_blank"
            class="link link-primary">GitHub</a
          ><br />
          <strong>Reach me:</strong> via GitHub or LinkedIn
        </p>
      </section>

      <!-- Comments -->
      <section>
        <h2 class="text-3xl font-bold mb-6">Comments</h2>
        <div class="giscus"></div>
      </section>

      <script>
        import {
          initGiscus,
          setupGiscusThemeObserver,
        } from "../../utils/giscus";

        // Initialize Giscus on page load
        initGiscus();

        // Setup theme change observer
        setupGiscusThemeObserver();
      </script>
    </div>
    <!-- End of blur wrapper -->
  </div>

  <style is:global>
    @keyframes unblurContent {
      0% {
        filter: blur(8px);
        opacity: 0.6;
      }
      100% {
        filter: blur(0);
        opacity: 1;
      }
    }

    /* accessibility: disable motion */
    @media (prefers-reduced-motion: reduce) {
      .motion-safe\:animate-\[unblurContent_1\.8s_ease-out_forwards] {
        animation: none !important;
        opacity: 1 !important;
        filter: none !important;
      }
    }
  </style>
</BaseLayout>
